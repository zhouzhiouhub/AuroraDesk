<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuroraDesk.Pages.GalleryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AuroraDesk.Models"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.Resources>
            <ItemsPanelTemplate x:Key="WrapPanelTemplate">
                <ItemsWrapGrid Orientation="Horizontal" ItemWidth="260" ItemHeight="180"/>
            </ItemsPanelTemplate>

            <Style x:Key="GalleryItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Margin" Value="8"/>
            </Style>
        </Grid.Resources>

        <ListView x:Name="WallpaperList"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="WallpaperList_ItemClick"
                  ItemsPanel="{StaticResource WrapPanelTemplate}"
                  ItemContainerStyle="{StaticResource GalleryItemStyle}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:WallpaperItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Image Source="{x:Bind ThumbnailPath}"
                                   Stretch="UniformToFill" Height="120"/>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="4"
                                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                    Foreground="White" Padding="8" CornerRadius="4">
                                <Button.Content>
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;"/>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout Opening="OnGalleryItemFlyoutOpening">
                                        <MenuFlyoutItem Text="设为壁纸" Icon="Accept" Click="OnSetAsWallpaperClick" Tag="{x:Bind}"/>
                                        <MenuFlyoutSubItem Text="设为壁纸到显示器"/>
                                        <MenuFlyoutItem Text="为所有显示器设置" Icon="Accept" Click="OnSetAsWallpaperAllClick" Tag="{x:Bind}"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="预览壁纸" Icon="View" Click="OnPreviewClick" Tag="{x:Bind}"/>
                                        <MenuFlyoutItem Text="打开文件所在位置" Icon="OpenLocal" Click="OnOpenLocationClick" Tag="{x:Bind}"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="删除壁纸" Icon="Delete" Click="OnDeleteClick" Tag="{x:Bind}"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="{x:Bind Title}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="2" Text="{x:Bind Description}"
                                   Opacity="0.7" FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>


