<Application x:Class="AuroraDesk.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AuroraDesk.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ═══════════════════════════════════════════ -->
            <!-- Brand palette                              -->
            <!-- ═══════════════════════════════════════════ -->
            <Color x:Key="BgDark">#FF0D1117</Color>
            <Color x:Key="BgCard">#FF161B22</Color>
            <Color x:Key="BgCardHover">#FF1C2333</Color>
            <Color x:Key="BgSurface">#FF21262D</Color>
            <Color x:Key="BorderSubtle">#FF30363D</Color>
            <Color x:Key="AuroraGreen">#FF6EEEB0</Color>
            <Color x:Key="AuroraPink">#FFFF6B8A</Color>
            <Color x:Key="AuroraYellow">#FFFFD866</Color>
            <Color x:Key="TextPrimary">#FFE6EDF3</Color>
            <Color x:Key="TextSecondary">#FF8B949E</Color>
            <Color x:Key="TextMuted">#FF656D76</Color>

            <SolidColorBrush x:Key="BgDarkBrush"          Color="{StaticResource BgDark}" />
            <SolidColorBrush x:Key="BgCardBrush"          Color="{StaticResource BgCard}" />
            <SolidColorBrush x:Key="BgCardHoverBrush"     Color="{StaticResource BgCardHover}" />
            <SolidColorBrush x:Key="BgSurfaceBrush"       Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BorderSubtleBrush"    Color="{StaticResource BorderSubtle}" />
            <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMuted}" />

            <LinearGradientBrush x:Key="AuroraGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource AuroraGreen}"  Offset="0" />
                <GradientStop Color="{StaticResource AuroraYellow}" Offset="0.5" />
                <GradientStop Color="{StaticResource AuroraPink}"   Offset="1" />
            </LinearGradientBrush>

            <DropShadowEffect x:Key="LogoGlow"
                              Color="{StaticResource AuroraGreen}"
                              BlurRadius="60" ShadowDepth="0" Opacity="0.35" />

            <!-- ═══════════════════════════════════════════ -->
            <!-- Value converters                           -->
            <!-- ═══════════════════════════════════════════ -->
            <conv:NullToVisibleConverter x:Key="NullToVisibleConverter" />
            <conv:NotNullToVisibleConverter x:Key="NotNullToVisibleConverter" />
            <conv:StartsWithActiveConverter x:Key="StartsWithActiveConverter" />
            <conv:BoolToVisibleConverter x:Key="BoolToVisibleConverter" />
            <conv:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter" />

            <!-- ═══════════════════════════════════════════ -->
            <!-- Custom ComboBox (dark theme)               -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Toggle button inside the ComboBox -->
            <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
                <Border x:Name="Bd" CornerRadius="6"
                        Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Padding="12,9,10,9"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="18" />
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0" />
                        <Path Grid.Column="1" Data="M 0 0 L 5 5 L 10 0"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.5" Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardHoverBrush}" />
                        <Setter TargetName="Bd" Property="BorderBrush">
                            <Setter.Value>
                                <SolidColorBrush Color="{StaticResource TextMuted}" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="Bd" Property="BorderBrush">
                            <Setter.Value>
                                <SolidColorBrush Color="{StaticResource AuroraGreen}" Opacity="0.5" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ComboBoxItem style -->
            <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd" Padding="10,7" CornerRadius="4"
                                    Background="Transparent" Margin="2,1">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource BgCardHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A6EEEB0" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox template -->
            <Style x:Key="DarkComboBox" TargetType="ComboBox">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Template="{StaticResource ComboBoxToggleButton}"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Focusable="False" ClickMode="Press" />
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  Margin="12,9,28,9"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                                <Popup x:Name="Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       Focusable="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Grid MinWidth="{TemplateBinding ActualWidth}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                          SnapsToDevicePixels="True"
                                          Margin="0,4,0,0">
                                        <Border CornerRadius="8"
                                                Background="{StaticResource BgCardBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                                BorderThickness="1"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="16"
                                                                  ShadowDepth="4" Opacity="0.4" />
                                            </Border.Effect>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!-- ScrollBar dark theme                       -->
            <!-- ═══════════════════════════════════════════ -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="6" />
                <Setter Property="Background" Value="Transparent" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
