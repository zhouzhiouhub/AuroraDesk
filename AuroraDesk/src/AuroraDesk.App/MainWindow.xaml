<Window x:Class="AuroraDesk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AuroraDesk"
        Width="960" Height="640"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Assets/AppIcon.ico">

    <Window.Resources>
        <!-- Entrance fade + slide animation -->
        <Storyboard x:Key="LogoEntrance">
            <DoubleAnimation Storyboard.TargetName="LogoPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.8"
                             BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoTranslate"
                             Storyboard.TargetProperty="Y"
                             From="30" To="0" Duration="0:0:0.8"
                             BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Title slides in slightly later -->
            <DoubleAnimation Storyboard.TargetName="TitlePanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.7"
                             BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleTranslate"
                             Storyboard.TargetProperty="Y"
                             From="20" To="0" Duration="0:0:0.7"
                             BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Subtitle fades last -->
            <DoubleAnimation Storyboard.TargetName="SubtitleBlock"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6"
                             BeginTime="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Version badge fades in -->
            <DoubleAnimation Storyboard.TargetName="VersionBadge"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"
                             BeginTime="0:0:1.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Subtle continuous glow pulse -->
            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                             Storyboard.TargetProperty="Opacity"
                             From="0.25" To="0.5" Duration="0:0:2.5"
                             BeginTime="0:0:1"
                             AutoReverse="True"
                             RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- Chromeless title bar button -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="46" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" BasedOn="{StaticResource TitleBarButton}" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#BF0F1D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LogoEntrance}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- Outer border with rounded corners -->
    <Border CornerRadius="12"
            Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Image Source="Assets/Square44x44Logo.altform-unplated_targetsize-48.png"
                           Width="28" Height="28"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" />
                    <TextBlock Text="AuroraDesk"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,1,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Stretch">
                    <Button Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButton}">
                        <Path Data="M4,0 L16,0" Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1" />
                    </Button>
                    <Button Click="MaximizeButton_Click"
                            Style="{StaticResource TitleBarButton}">
                        <Rectangle Width="10" Height="10"
                                   Stroke="{StaticResource TextSecondaryBrush}"
                                   StrokeThickness="1" Fill="Transparent" />
                    </Button>
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButton}">
                        <Path Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main content area -->
            <Grid Grid.Row="1">
                <!-- Background aurora glow decorations -->
                <Canvas ClipToBounds="True" IsHitTestVisible="False">
                    <!-- Top-left aurora blob -->
                    <Ellipse Canvas.Left="-120" Canvas.Top="-80"
                             Width="400" Height="400" Opacity="0.06">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{StaticResource AuroraGreen}" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Bottom-right aurora blob -->
                    <Ellipse Canvas.Right="-100" Canvas.Bottom="-60"
                             Width="500" Height="500" Opacity="0.05"
                             Canvas.Left="560" Canvas.Top="200">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{StaticResource AuroraPink}" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>

                <!-- Center content -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <!-- Logo image with glow -->
                    <Grid x:Name="LogoPanel" Opacity="0"
                          HorizontalAlignment="Center">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="LogoTranslate" Y="30" />
                        </Grid.RenderTransform>

                        <!-- Glow behind the logo -->
                        <Ellipse x:Name="GlowEffect"
                                 Width="200" Height="200"
                                 Opacity="0.3"
                                 IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{StaticResource AuroraGreen}" Offset="0" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Logo icon -->
                        <Border Width="120" Height="120"
                                CornerRadius="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <ImageBrush ImageSource="Assets/Square150x150Logo.scale-200.png"
                                            Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                    </Grid>

                    <!-- App title with gradient -->
                    <StackPanel x:Name="TitlePanel" Opacity="0"
                                Margin="0,28,0,0"
                                HorizontalAlignment="Center">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="TitleTranslate" Y="20" />
                        </StackPanel.RenderTransform>

                        <TextBlock Text="AuroraDesk"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Variable Display, Segoe UI">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource AuroraGreen}"  Offset="0" />
                                    <GradientStop Color="{StaticResource AuroraYellow}" Offset="0.5" />
                                    <GradientStop Color="{StaticResource AuroraPink}"   Offset="1" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>

                    <!-- Subtitle -->
                    <TextBlock x:Name="SubtitleBlock"
                               Text="Dynamic Wallpaper Engine for Windows"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Opacity="0"
                               FontFamily="Segoe UI Variable Text, Segoe UI" />

                    <!-- Version badge -->
                    <Border x:Name="VersionBadge"
                            Opacity="0"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0"
                            CornerRadius="12"
                            Padding="14,6"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            Background="{StaticResource BgCardBrush}">
                        <TextBlock Text="v0.1.0-alpha"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI Variable Text, Segoe UI" />
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
